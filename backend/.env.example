APP_NAME=Starter API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
ALLOWED_ORIGINS=http://localhost:3000

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Choose one DB_ENGINE based on your database:
# - PostgreSQL: django.db.backends.postgresql
# - MySQL: django.db.backends.mysql
# - SQLite: django.db.backends.sqlite3
DB_ENGINE=django.db.backends.postgresql
DB_NAME=fastnext_db
DB_USER=postgres
DB_PASSWORD=password123

# DB_HOST reference:
# - Docker + PostgreSQL: postgres
# - Docker + MySQL: mysql
# - Local (without Docker): localhost
DB_HOST=localhost
DB_PORT=5432

# Optional: if set, this will override DB_ENGINE/DB_NAME/DB_USER/DB_PASSWORD/DB_HOST/DB_PORT
# PostgreSQL local example:
# DATABASE_URL=postgresql+psycopg://postgres:password123@localhost:5432/fastnext_db
# PostgreSQL docker example:
# DATABASE_URL=postgresql+psycopg://postgres:password123@postgres:5432/fastnext_db
